								"exec": [
									"const secretKey = pm.collectionVariables.get(\"secret\");\r",
									"\r",
									"// Set timezone offset to GMT+7\r",
									"function getTimestampWithTimezoneOffset() {\r",
									"    const date = new Date();\r",
									"    // Menyesuaikan jam ke GMT+7\r",
									"    const offset = 7 * 60; // Offset dalam menit untuk GMT+7\r",
									"    const localTime = date.getTime();\r",
									"    const localOffset = date.getTimezoneOffset() * 60000; // Offset waktu lokal dalam milidetik\r",
									"    const utc = localTime + localOffset;\r",
									"    const jakartaTime = new Date(utc + (offset * 60000));\r",
									"    // Menghasilkan timestamp dengan format yang diinginkan\r",
									"    const isoString = jakartaTime.toISOString();\r",
									"    const timestampWithoutMillis = isoString.slice(0, 19) + \"+07:00\"; // Menghilangkan mili-detik dan menambahkan +07:00\r",
									"    return timestampWithoutMillis;\r",
									"}\r",
									"// Set timestamp as environment or collection variable\r",
									"const timestamp = getTimestampWithTimezoneOffset();\r",
									"pm.collectionVariables.set(\"timestamp\", timestamp);\r",
									"\r",
									"const requestBody = pm.request.body.raw; // Ambil body dari request\r",
									"const minifiedBody = JSON.stringify(JSON.parse(requestBody)); // Minify JSON body\r",
									"\r",
									"const message = 'POST:/analysis/online:'+pm.collectionVariables.get(\"token\")+':'+minifiedBody+':'+pm.collectionVariables.get(\"timestamp\");\r",
									"const hash = CryptoJS.HmacSHA512(message, secretKey);\r",
									"const hashInBase64 = hash.toString(CryptoJS.enc.Base64);\r",
									"const hashInHex = hash.toString(CryptoJS.enc.Hex);\r",
									"\r",
									"// Set hash as an environment or collection variable\r",
									"pm.collectionVariables.set(\"hmac_hash\", hashInHex); // Simpan hasil hash\r",
									"pm.collectionVariables.set(\"minifiedBody\", minifiedBody); // Simpan hasil hash"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
